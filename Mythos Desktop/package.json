{
  "name": "mythos-desktop",
  "private": true,
  "version": "1.0.0",
  "description": "Mythos Desktop - Autonomous AI Agent",
  "author": "Mythos Team",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-packager . \"Mythos Desktop\" --platform=win32 --arch=x64 --out=release --overwrite --ignore=node_modules"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.6.1",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.1.2",
    "electron": "^35.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "wait-on": "^8.0.3"
  }
}
